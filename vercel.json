{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/api/transactions/upload", "destination": "/api/transactions?action=upload" },
    { "source": "/api/recommendations/refresh", "destination": "/api/recommendations?action=refresh" },
    { "source": "/api/recommendations/:retailer_id", "destination": "/api/recommendations?retailer_id=:retailer_id" },
    { "source": "/api/insights/:retailer_id", "destination": "/api/insights?retailer_id=:retailer_id" }
  ]
}
